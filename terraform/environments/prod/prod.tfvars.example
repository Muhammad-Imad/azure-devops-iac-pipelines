# Example tfvars for the prod environment.
# Copy to prod.tfvars and supply real values, or pass via pipeline variables.
# Never commit real subscription/tenant IDs or secrets.

subscription_id    = "00000000-0000-0000-0000-000000000000"
tenant_id          = "00000000-0000-0000-0000-000000000000"
location           = "westeurope"
secondary_location = "northeurope"
environment        = "prod"
org                = "acme"

aks_admin_group_object_ids = [
  "22222222-2222-2222-2222-222222222222",
]

ci_runner_ip_ranges = [
  "203.0.113.0/24",
]

tags = {
  cost_center = "platform-engineering"
  owner       = "sre-team"
  compliance  = "pci-dss"
}
