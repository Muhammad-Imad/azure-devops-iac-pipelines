# Example tfvars for the dev environment.
# Copy to dev.tfvars and supply real values, or pass via pipeline variables.
# Never commit real subscription/tenant IDs or secrets.

subscription_id = "00000000-0000-0000-0000-000000000000"
tenant_id       = "00000000-0000-0000-0000-000000000000"
location        = "westeurope"
environment     = "dev"
org             = "acme"

# Entra ID group(s) granted AKS cluster-admin (Azure RBAC).
aks_admin_group_object_ids = [
  "11111111-1111-1111-1111-111111111111",
]

# CIDR ranges of CI runners allowed through the Key Vault firewall.
ci_runner_ip_ranges = [
  "203.0.113.0/24",
]

tags = {
  cost_center = "platform-engineering"
  owner       = "sre-team"
}
